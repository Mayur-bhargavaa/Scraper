{
  "name": "stitchbyte-lead-gen",
  "version": "1.0.0",
  "private": true,
  "description": "Stitchbyte — Google Maps Lead Generation System",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=client",
    "start": "npm run start --workspace=server",
    "setup:prod": "bash scripts/deploy-prod.sh"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "lucide-react": "^1.7.0"
  }
}
