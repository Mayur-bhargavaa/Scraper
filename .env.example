# ─── Server ───
PORT=5000
NODE_ENV=development

# ─── MongoDB ───
MONGODB_URI=mongodb://localhost:27017/stitchbyte

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=

# ─── JWT ───
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── Google Places API (optional fallback) ───
GOOGLE_PLACES_API_KEY=

# ─── Proxy Configuration ───
PROXY_ENABLED=false
PROXY_PROVIDER=brightdata
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# ─── CAPTCHA Solver ───
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=2captcha
CAPTCHA_API_KEY=

# ─── Scraper Settings ───
SCRAPER_MAX_CONCURRENCY=3
SCRAPER_MIN_DELAY=2000
SCRAPER_MAX_DELAY=7000
SCRAPER_HEADLESS=true

# ─── Client ───
CLIENT_URL=http://localhost:5173
